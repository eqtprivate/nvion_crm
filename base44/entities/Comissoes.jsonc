      "format": "date",
      "title": "Data Confirma\u00e7\u00e3o",
      "type": "string"
    },
    "data_pagamento": {
      "format": "date",
      "title": "Data Pagamento",
      "type": "string"
    },
    "data_prevista_pagamento": {
      "format": "date",
      "title": "Data Prevista Pagamento",
      "type": "string"
    },
    "empresa_vinculada": {
      "title": "Empresa",
      "type": "string"
    },
    "equipe": {
      "title": "Equipe",
      "type": "string"
    },
    "lider": {
      "title": "L\u00edder",
      "type": "string"
    },
    "observacoes": {
      "title": "Observa\u00e7\u00f5es",
      "type": "string"
    },
    "origem": {
      "title": "Origem",
      "type": "string"
    },
    "percentual_base": {
      "title": "Percentual Base (%)",
      "type": "number"
    },
    "percentual_lider": {
      "title": "Percentual L\u00edder (%)",
