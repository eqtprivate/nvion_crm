    },
    "produto": {
      "title": "Produto",
      "type": "string"
    },
    "regra_comissao": {
      "title": "Regra de Comiss\u00e3o",
      "type": "string"
    },
    "status_comissao": {
      "default": "prevista",
      "enum": [
        "prevista",
        "confirmada",
        "liberada",
        "paga",
        "bloqueada",
        "estornada",
        "cancelada"
      ],
      "title": "Status",
      "type": "string"
    },
    "valor_carta": {
      "title": "Valor da Carta",
      "type": "number"
    },
    "valor_comissao_lider": {
      "title": "Comiss\u00e3o L\u00edder",
      "type": "number"
    },
    "valor_comissao_total": {
      "title": "Comiss\u00e3o Total",
