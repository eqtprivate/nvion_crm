{
  "name": "ProdutoConsorcio",
  "type": "object",
  "properties": {
    "empresa_vinculada": {
      "type": "string",
      "description": "Empresa vinculada"
    },
    "administradora_vinculada": {
      "type": "string",
      "description": "Administradora vinculada"
    },
    "nome_produto": {
      "type": "string",
      "description": "Nome do produto"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "imovel",
        "veiculo",
        "pesados",
        "servicos",
        "agro",
        "outros"
      ],
      "default": "veiculo",
      "description": "Categoria do produto"
    },
    "percentual_comissao_padrao": {
      "type": "number",
      "description": "Percentual de comissao padrao"
    },
    "prazo_medio_pagamento": {
      "type": "number",
      "description": "Prazo medio de pagamento (dias)"
    },
    "status": {
      "type": "string",
      "enum": [
        "ativo",
        "inativo"
      ],
      "default": "ativo",
      "description": "Status do produto"
    },
    "observacoes": {
      "type": "string",
      "description": "Observacoes"
    }
  },
  "required": [
    "nome_produto"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.empresa_vinculada": "{{user.data.empresa_vinculada}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.empresa_vinculada": "{{user.data.empresa_vinculada}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.empresa_vinculada": "{{user.data.empresa_vinculada}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.empresa_vinculada": "{{user.data.empresa_vinculada}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    }
  }
}